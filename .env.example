# Copy to .env and fill in all required values before running docker compose up.
# Variables without defaults will cause docker compose to fail loudly if unset.
ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=subly
POSTGRES_PASSWORD=              # required — set a strong password
POSTGRES_DB=subly

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_USER=subly
RABBITMQ_PASS=                  # required — set a strong password

# ── Clerk (https://dashboard.clerk.com → API Keys) ────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ── OpenAI (embeddings + fraud LLM) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pinecone (https://app.pinecone.io) ────────────────────────────────────────
# Create an index named subly-listings, dimension 1536, metric cosine
PINECONE_API_KEY=...
PINECONE_INDEX=subly-listings

# ── Stripe (https://dashboard.stripe.com → Developers → API Keys) ─────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Local: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Production: Stripe dashboard → Webhooks → endpoint secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Service-to-service auth ────────────────────────────────────────────────────
INTERNAL_SECRET=                # required — generate with: openssl rand -hex 32

# ── Admin and invite ───────────────────────────────────────────────────────────
ADMIN_SECRET=                   # required — generate with: openssl rand -hex 32
ADMIN_USER_IDS=                 # comma-separated Clerk user IDs granted /admin access
INVITE_SECRET=                  # required — generate with: openssl rand -hex 32

# ── URLs ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── AWS S3 — listing image uploads (optional) ─────────────────────────────────
# Omit to run without image upload support
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=subly-listing-images

# ── Resend — transactional email (optional) ────────────────────────────────────
# Magic links log to stdout when unset
RESEND_API_KEY=
FROM_EMAIL=Subly <invites@subly.app>
